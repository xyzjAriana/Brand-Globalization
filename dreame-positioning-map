            const g = svg.append('g')
                .attr('transform', `translate(${margin.left},${margin.top})`);

            // Scales
            const xScale = d3.scaleLinear().domain([0, 10]).range([0, innerWidth]);
            const yScale = d3.scaleLinear().domain([0, 10]).range([innerHeight, 0]);

            // Grid lines
            const xTicks = [0, 2, 4, 6, 8, 10];
            const yTicks = [0, 2, 4, 6, 8, 10];

            g.selectAll('.grid-x')
                .data(xTicks)
                .enter()
                .append('line')
                .attr('class', 'grid-line')
                .attr('x1', d => xScale(d))
                .attr('x2', d => xScale(d))
                .attr('y1', 0)
                .attr('y2', innerHeight);

            g.selectAll('.grid-y')
                .data(yTicks)
                .enter()
                .append('line')
                .attr('class', 'grid-line')
                .attr('x1', 0)
                .attr('x2', innerWidth)
                .attr('y1', d => yScale(d))
                .attr('y2', d => yScale(d));

            // Axes
            g.append('line')
                .attr('class', 'axis-line')
                .attr('x1', 0)
                .attr('x2', innerWidth)
                .attr('y1', yScale(5))
                .attr('y2', yScale(5));

            g.append('line')
                .attr('class', 'axis-line')
                .attr('x1', xScale(5))
                .attr('x2', xScale(5))
                .attr('y1', 0)
                .attr('y2', innerHeight);

            // Axis labels
            g.append('text')
                .attr('class', 'quadrant-label')
                .attr('x', innerWidth - 10)
                .attr('y', yScale(5) - 10)
                .attr('text-anchor', 'end')
                .text('Technical Complexity →');

            g.append('text')
                .attr('class', 'quadrant-label')
                .attr('x', xScale(5) + 10)
                .attr('y', 20)
                .text('↑ Price Positioning');

            // Quadrant labels
            const quadrants = [
                { x: 2.5, y: 8.5, label: "Premium Tech", sub: "High-Tech Focus" },
                { x: 7.5, y: 8.5, label: "Luxury Ecosystem", sub: "Full-Scene Smart" },
                { x: 2.5, y: 1.5, label: "Value Practical", sub: "Entry-Level Focus" },
                { x: 7.5, y: 1.5, label: "Mass Smart", sub: "Smart for Everyone" }
            ];

            quadrants.forEach(q => {
                g.append('text')
                    .attr('x', xScale(q.x))
                    .attr('y', yScale(q.y))
                    .attr('text-anchor', 'middle')
                    .attr('fill', 'rgba(148, 163, 184, 0.3)')
                    .attr('font-size', '14px')
                    .attr('font-weight', 'bold')
                    .text(q.label);
                
                g.append('text')
                    .attr('x', xScale(q.x))
                    .attr('y', yScale(q.y) - 20)
                    .attr('text-anchor', 'middle')
                    .attr('fill', 'rgba(148, 163, 184, 0.2)')
                    .attr('font-size', '10px')
                    .text(q.sub);
            });

            // Draw connections between related markets
            const connections = [
                ['germany', 'france'],
                ['france', 'italy'],
                ['japan', 'korea'],
                ['korea', 'singapore'],
                ['singapore', 'australia'],
                ['china', 'usa'],
                ['china', 'germany']
            ];

            connections.forEach(([source, target]) => {
                if (marketData[source] && marketData[target]) {
                    g.append('line')
                        .attr('class', 'connection-line')
                        .attr('x1', xScale(marketData[source].coordinates[0]))
                        .attr('y1', yScale(marketData[source].coordinates[1]))
                        .attr('x2', xScale(marketData[target].coordinates[0]))
                        .attr('y2', yScale(marketData[target].coordinates[1]));
                }
            });

            // Draw competitors first (behind)
            Object.keys(marketData).forEach(key => {
                const market = marketData[key];
                market.competitors.forEach(comp => {
                    g.append('circle')
                        .attr('class', 'competitor-dot')
                        .attr('cx', xScale(comp.position[0]))
                        .attr('cy', yScale(comp.position[1]))
                        .attr('r', 6)
                        .attr('fill', 'rgba(248, 113, 113, 0.6)')
                        .attr('stroke', 'rgba(248, 113, 113, 0.8)')
                        .attr('stroke-width', 2)
                        .on('mouseover', function(event) {
                            showTooltip(event, `
                                <div class="text-xs">
                                    <div class="font-bold text-red-400">${comp.name}</div>
                                    <div class="text-slate-300">Market Share: ${comp.share}</div>
                                    <div class="text-slate-400">Competitor</div>
                                </div>
                            `);
                        })
                        .on('mouseout', hideTooltip);
                });
            });

            // Draw Dreame market nodes
            const colorScale = d3.scaleOrdinal()
                .domain(['germany', 'france', 'italy', 'usa', 'japan', 'korea', 'singapore', 'australia', 'china'])
                .range(['#3b82f6', '#60a5fa', '#818cf8', '#a855f7', '#ec4899', '#eab308', '#10b981', '#14b8a6', '#ef4444']);

            Object.keys(marketData).forEach(key => {
                const market = marketData[key];
                const [x, y] = market.coordinates;
                
                const nodeGroup = g.append('g')
                    .attr('class', 'market-node')
                    .attr('transform', `translate(${xScale(x)}, ${yScale(y)})`)
                    .on('click', () => showMarketDetail(key))
                    .on('mouseover', function(event) {
                        d3.select(this).select('circle').attr('r', 25);
                        showTooltip(event, `
                            <div class="text-xs">
                                <div class="font-bold text-cyan-400 text-base mb-1">${market.name}</div>
                                <div class="text-slate-300 mb-1">Share: ${market.share}</div>
                                <div class="text-slate-400 italic">"${market.positioning.claim}"</div>
                                <div class="mt-2 text-cyan-300">Click for details →</div>
                            </div>
                        `);
                    })
                    .on('mouseout', function() {
                        d3.select(this).select('circle').attr('r', 20);
                        hideTooltip();
                    });

                // Outer glow
                nodeGroup.append('circle')
                    .attr('r', 20)
                    .attr('fill', colorScale(key))
                    .attr('opacity', 0.3)
                    .attr('filter', 'blur(8px)');

                // Main circle
                nodeGroup.append('circle')
                    .attr('r', 20)
                    .attr('fill', 'rgba(30, 41, 59, 0.9)')
                    .attr('stroke', colorScale(key))
                    .attr('stroke-width', 3);

                // Inner icon/text
                nodeGroup.append('text')
                    .attr('text-anchor', 'middle')
                    .attr('dy', '0.35em')
                    .attr('fill', colorScale(key))
                    .attr('font-size', '10px')
                    .attr('font-weight', 'bold')
                    .text(key.substring(0, 2).toUpperCase());

                // Market share label
                nodeGroup.append('text')
                    .attr('text-anchor', 'middle')
                    .attr('dy', 35)
                    .attr('fill', 'rgba(226, 232, 240, 0.8)')
                    .attr('font-size', '11px')
                    .attr('font-weight', '600')
                    .text(market.share);

                // Country label
                nodeGroup.append('text')
                    .attr('text-anchor', 'middle')
                    .attr('dy', 50)
                    .attr('fill', 'rgba(148, 163, 184, 0.6)')
                    .attr('font-size', '9px')
                    .text(market.name.split(' ')[0]);
            });

            // White space indicators
            const whiteSpaces = [
                { x: 1, y: 3, label: "Middle East", opportunity: "Luxury segment underserved" },
                { x: 3, y: 2, label: "India", opportunity: "Entry-level price point" },
                { x: 6, y: 1.5, label: "LatAm", opportunity: "Mid-tier growth" }
            ];

            whiteSpaces.forEach(ws => {
                g.append('rect')
                    .attr('x', xScale(ws.x) - 30)
                    .attr('y', yScale(ws.y) - 20)
                    .attr('width', 60)
                    .attr('height', 40)
                    .attr('rx', 8)
                    .attr('fill', 'rgba(16, 185, 129, 0.1)')
                    .attr('stroke', 'rgba(16, 185, 129, 0.4)')
                    .attr('stroke-width', 1)
                    .attr('stroke-dasharray', '4,4');

                g.append('text')
                    .attr('x', xScale(ws.x))
                    .attr('y', yScale(ws.y))
                    .attr('text-anchor', 'middle')
                    .attr('dy', '0.35em')
                    .attr('fill', 'rgba(16, 185, 129, 0.8)')
                    .attr('font-size', '10px')
                    .attr('font-weight', 'bold')
                    .text(ws.label);
            });
        }

        function drawCompetitiveView() {
            svg.selectAll('*').remove();
            
            const margin = { top: 40, right: 40, bottom: 40, left: 200 };
            const innerWidth = width - margin.left - margin.right;
            const innerHeight = height - margin.top - margin.bottom;

            const g = svg.append('g')
                .attr('transform', `translate(${margin.left},${margin.top})`);

            // Competitive landscape data
            const competitors = [
                { name: "Dreame", share: 11.3, growth: 178, color: "#38bdf8" },
                { name: "Roborock", share: 19.3, growth: 50.7, color: "#f472b6" },
                { name: "Ecovacs", share: 13.6, growth: 11, color: "#a78bfa" },
                { name: "Xiaomi", share: 9.9, growth: 15, color: "#fb923c" },
                { name: "iRobot", share: 9.3, growth: -30.6, color: "#94a3b8" }
            ];

            const xScale = d3.scaleLinear().domain([0, 25]).range([0, innerWidth]);
            const yScale = d3.scaleBand().domain(competitors.map(d => d.name)).range([0, innerHeight]).padding(0.3);

            // Bars
            competitors.forEach((comp, i) => {
                const barGroup = g.append('g');
                
                // Background bar
                barGroup.append('rect')
                    .attr('x', 0)
                    .attr('y', yScale(comp.name))
                    .attr('width', innerWidth)
                    .attr('height', yScale.bandwidth())
                    .attr('fill', 'rgba(30, 41, 59, 0.5)')
                    .attr('rx', 4);

                // Data bar
                barGroup.append('rect')
                    .attr('x', 0)
                    .attr('y', yScale(comp.name))
                    .attr('width', xScale(comp.share))
                    .attr('height', yScale.bandwidth())
                    .attr('fill', comp.color)
                    .attr('rx', 4)
                    .attr('opacity', 0.8);

                // Label
                g.append('text')
                    .attr('x', -10)
                    .attr('y', yScale(comp.name) + yScale.bandwidth()/2)
                    .attr('text-anchor', 'end')
                    .attr('dy', '0.35em')
                    .attr('fill', comp.color)
                    .attr('font-size', '12px')
                    .attr('font-weight', 'bold')
                    .text(comp.name);

                // Share value
                g.append('text')
                    .attr('x', xScale(comp.share) + 10)
                    .attr('y', yScale(comp.name) + yScale.bandwidth()/2)
                    .attr('dy', '0.35em')
                    .attr('fill', '#e2e8f0')
                    .attr('font-size', '12px')
                    .attr('font-weight', 'bold')
                    .text(comp.share + '%');

                // Growth indicator
                const growthColor = comp.growth > 0 ? '#10b981' : '#ef4444';
                const growthIcon = comp.growth > 0 ? '↑' : '↓';
                
                g.append('text')
                    .attr('x', innerWidth - 80)
                    .attr('y', yScale(comp.name) + yScale.bandwidth()/2)
                    .attr('dy', '0.35em')
                    .attr('fill', growthColor)
                    .attr('font-size', '11px')
                    .text(`${growthIcon} ${Math.abs(comp.growth)}% YoY`);
            });

            // Title
            g.append('text')
                .attr('x', innerWidth/2)
                .attr('y', -20)
                .attr('text-anchor', 'middle')
                .attr('fill', '#e2e8f0')
                .attr('font-size', '14px')
                .attr('font-weight', 'bold')
                .text('Global Smart Robot Vacuum Market Share Q1 2025 (IDC Data)');
        }

        function drawEvolutionView() {
            svg.selectAll('*').remove();
            
            const margin = { top: 60, right: 60, bottom: 60, left: 60 };
            const innerWidth = width - margin.left - margin.right;
            const innerHeight = height - margin.top - margin.bottom;

            const g = svg.append('g')
                .attr('transform', `translate(${margin.left},${margin.top})`);

            // Timeline data
            const timeline = [
                { year: 2018, event: "Brand Founded", markets: 1, positioning: "Technology-Driven" },
                { year: 2019, event: "Europe Entry", markets: 3, positioning: "Engineering Excellence" },
                { year: 2020, event: "Asia Expansion", markets: 8, positioning: "Detail Perfection" },
                { year: 2022, event: "USA Breakthrough", markets: 15, positioning: "Disruptive Innovation" },
                { year: 2024, event: "Global Leader", markets: 30, positioning: "Ecosystem Definition" },
                { year: 2025, event: "Appliance Extension", markets: 100, positioning: "Full-Scene Smart" }
            ];

            const xScale = d3.scaleLinear().domain([2018, 2025]).range([0, innerWidth]);
            const yScale = d3.scaleLinear().domain([0, 100]).range([innerHeight, 0]);

            // Line
            const line = d3.line()
                .x(d => xScale(d.year))
                .y(d => yScale(d.markets))
                .curve(d3.curveMonotoneX);

            // Area under line
            const area = d3.area()
                .x(d => xScale(d.year))
                .y0(innerHeight)
                .y1(d => yScale(d.markets))
                .curve(d3.curveMonotoneX);

            g.append('path')
                .datum(timeline)
                .attr('fill', 'rgba(56, 189, 248, 0.2)')
                .attr('d', area);

            g.append('path')
                .datum(timeline)
                .attr('fill', 'none')
                .attr('stroke', '#38bdf8')
                .attr('stroke-width', 3)
                .attr('d', line);

            // Points
            timeline.forEach(d => {
                const point = g.append('g')
                    .attr('transform', `translate(${xScale(d.year)}, ${yScale(d.markets)})`);

                point.append('circle')
                    .attr('r', 8)
                    .attr('fill', '#0f172a')
                    .attr('stroke', '#38bdf8')
                    .attr('stroke-width', 3);

                point.append('text')
                    .attr('text-anchor', 'middle')
                    .attr('dy', -15)
                    .attr('fill', '#e2e8f0')
                    .attr('font-size', '11px')
                    .attr('font-weight', 'bold')
                    .text(d.markets);

                point.append('text')
                    .attr('text-anchor', 'middle')
                    .attr('dy', 25)
                    .attr('fill', '#94a3b8')
                    .attr('font-size', '9px')
                    .text(d.year);

                // Event label
                point.append('text')
                    .attr('text-anchor', 'middle')
                    .attr('dy', 40)
                    .attr('fill', '#38bdf8')
                    .attr('font-size', '10px')
                    .text(d.event);

                // Positioning label
                point.append('text')
                    .attr('text-anchor', 'middle')
                    .attr('dy', 55)
                    .attr('fill', 'rgba(148, 163, 184, 0.8)')
                    .attr('font-size', '9px')
                    .text(d.positioning);
            });

            // Axis
            g.append('text')
                .attr('x', innerWidth/2)
                .attr('y', -30)
                .attr('text-anchor', 'middle')
                .attr('fill', '#e2e8f0')
                .attr('font-size', '14px')
                .attr('font-weight', 'bold')
                .text('Dreame Globalization Strategy Evolution (2018-2025)');
        }

        function switchView(view) {
            currentView = view;
            
            // Update buttons
            ['positioning', 'competitive', 'evolution'].forEach(v => {
                const btn = document.getElementById(`btn-${v}`);
                if (v === view) {
                    btn.classList.add('tab-active');
                    btn.classList.remove('bg-slate-700/50', 'text-slate-300');
                } else {
                    btn.classList.remove('tab-active');
                    btn.classList.add('bg-slate-700/50', 'text-slate-300');
                }
            });

            // Redraw
            if (view === 'positioning') drawPositioningView();
            else if (view === 'competitive') drawCompetitiveView();
            else if (view === 'evolution') drawEvolutionView();
        }

        function showMarketDetail(marketKey) {
            const data = marketData[marketKey];
            if (!data) return;

            document.getElementById('default-card').classList.add('hidden');
            document.getElementById('detail-card').classList.remove('hidden');

            document.getElementById('market-title').textContent = data.name;
            document.getElementById('market-share').textContent = `Share: ${data.share}`;
            document.getElementById('positioning-claim').textContent = `"${data.positioning.claim}"`;
            
            const rationalList = document.getElementById('rational-benefits');
            rationalList.innerHTML = data.positioning.rational.map(b => `<li class="flex items-start gap-2"><span class="text-cyan-400 mt-1">•</span>${b}</li>`).join('');
            
            const emotionalList = document.getElementById('emotional-benefits');
            emotionalList.innerHTML = data.positioning.emotional.map(b => `<li class="flex items-start gap-2"><span class="text-pink-400 mt-1">•</span>${b}</li>`).join('');
            
            document.getElementById('target-persona').textContent = data.positioning.persona;
            
            const compDiv = document.getElementById('competitors');
            compDiv.innerHTML = data.positioning.competitors.map(c => 
                `<span class="px-2 py-1 bg-red-500/20 text-red-300 rounded text-xs">${c}</span>`
            ).join('');
            
            document.getElementById('cultural-values').textContent = data.positioning.cultural;
            
            document.getElementById('strategy-score').style.width = data.positioning.strategyScore + '%';
            document.getElementById('strategy-label').textContent = data.positioning.strategyLabel;
        }

        function highlightMarket(marketKey) {
            showMarketDetail(marketKey);
            
            // Visual feedback on chart
            svg.selectAll('.market-node')
                .transition()
                .duration(300)
                .attr('opacity', function() {
                    const transform = d3.select(this).attr('transform');
                    return transform && transform.includes(marketData[marketKey].coordinates[0]) ? 1 : 0.3;
                });
            
            setTimeout(() => {
                svg.selectAll('.market-node')
                    .transition()
                    .duration(300)
                    .attr('opacity', 1);
            }, 2000);
        }

        function showTooltip(event, content) {
            const tooltip = document.getElementById('tooltip');
            const tooltipContent = document.getElementById('tooltip-content');
            
            tooltipContent.innerHTML = content;
            tooltip.style.left = (event.pageX + 15) + 'px';
            tooltip.style.top = (event.pageY - 10) + 'px';
            tooltip.classList.add('active');
        }

        function hideTooltip() {
            document.getElementById('tooltip').classList.remove('active');
        }

        // Initialize
        window.addEventListener('load', initViz);
        window.addEventListener('resize', () => {
            const container = document.getElementById('viz-container');
            width = container.clientWidth;
            height = container.clientHeight;
            svg.attr('width', width).attr('height', height);
            switchView(currentView);
        });
    </script>
</body>
</html>
